generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RelationshipType {
  PARTNER
  FAMILY
  FRIEND
  COLLEAGUE
  OTHER
}

enum PreferenceCategory {
  FOOD
  RESTAURANT
  GIFT
  PLACE
  OTHER
}

enum EventSource {
  USER
  SYSTEM
}

enum ReminderChannel {
  EMAIL
  PUSH
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

model UserProfile {
  id          String   @id @default(cuid())
  clerkUserId String   @unique @map("clerk_user_id")
  email       String
  locale      String   @default("en")
  timezone    String   @default("UTC")
  countryCode String   @map("country_code")
  regionCode  String?  @map("region_code")
  theme       ThemePreference @default(LIGHT)
  onboardingCompleted Boolean @default(false) @map("onboarding_completed")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  people         Person[]
  events         Event[]
  hiddenHolidays UserHiddenHoliday[]
  subscription   Subscription?
  deviceTokens   DeviceToken[]

  @@map("user_profiles")
}

model Subscription {
  id               String             @id @default(cuid())
  userProfileId    String             @unique @map("user_profile_id")
  plan             SubscriptionPlan   @default(FREE)
  status           SubscriptionStatus @default(ACTIVE)
  stripeCustomerId String?            @map("stripe_customer_id")
  stripeSubscriptionId String?        @map("stripe_subscription_id")
  currentPeriodEnd DateTime?          @map("current_period_end")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  userProfile UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Person {
  id            String           @id @default(cuid())
  userProfileId String           @map("user_profile_id")
  name          String
  relationship  RelationshipType @default(OTHER)
  notes         String?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  userProfile UserProfile   @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  preferences Preference[]
  personNotes PersonNote[]
  eventPeople EventPerson[]

  @@index([userProfileId])
  @@map("people")
}

model Preference {
  id        String             @id @default(cuid())
  personId  String             @map("person_id")
  category  PreferenceCategory
  label     String
  value     String
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@map("preferences")
}

model PersonNote {
  id        String   @id @default(cuid())
  personId  String   @map("person_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@map("person_notes")
}

model Event {
  id            String      @id @default(cuid())
  userProfileId String      @map("user_profile_id")
  title         String
  description   String?
  date          DateTime?   @db.Date
  isRecurring   Boolean     @default(false) @map("is_recurring")
  isUndated     Boolean     @default(false) @map("is_undated")
  source        EventSource @default(USER)
  holidayKey    String?     @map("holiday_key")
  countryCode   String?     @map("country_code")
  year          Int?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  userProfile UserProfile   @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  eventPeople EventPerson[]
  eventNotes  EventNote[]
  reminders   Reminder[]

  @@index([userProfileId, date])
  @@index([userProfileId, isUndated])
  @@map("events")
}

model EventPerson {
  id       String @id @default(cuid())
  eventId  String @map("event_id")
  personId String @map("person_id")

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([eventId, personId])
  @@map("event_people")
}

model EventNote {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_notes")
}

model Reminder {
  id         String          @id @default(cuid())
  eventId    String          @map("event_id")
  daysBefore Int             @map("days_before")
  channel    ReminderChannel @default(EMAIL)
  isActive   Boolean         @default(true) @map("is_active")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  event      Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  deliveries ReminderDelivery[]

  @@unique([eventId, daysBefore, channel])
  @@index([eventId])
  @@map("reminders")
}

model ReminderDelivery {
  id             String   @id @default(cuid())
  reminderId     String   @map("reminder_id")
  occurrenceDate DateTime @db.Date @map("occurrence_date")
  sentAt         DateTime @default(now()) @map("sent_at")

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@unique([reminderId, occurrenceDate])
  @@map("reminder_deliveries")
}

model SystemHoliday {
  id           String   @id @default(cuid())
  countryCode  String   @map("country_code")
  regionCode   String   @default("") @map("region_code")
  year         Int
  holidayKey   String   @map("holiday_key")
  title        String
  date         DateTime @db.Date
  isMovable    Boolean  @default(false) @map("is_movable")
  lastSyncedAt DateTime @map("last_synced_at")

  hiddenBy UserHiddenHoliday[]

  @@unique([countryCode, regionCode, year, holidayKey])
  @@index([countryCode, year])
  @@map("system_holidays")
}

model UserHiddenHoliday {
  id              String @id @default(cuid())
  userProfileId   String @map("user_profile_id")
  systemHolidayId String @map("system_holiday_id")

  userProfile   UserProfile   @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  systemHoliday SystemHoliday @relation(fields: [systemHolidayId], references: [id], onDelete: Cascade)

  @@unique([userProfileId, systemHolidayId])
  @@map("user_hidden_holidays")
}

model DeviceToken {
  id            String         @id @default(cuid())
  userProfileId String         @map("user_profile_id")
  token         String         @unique
  platform      DevicePlatform
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  userProfile UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@index([userProfileId])
  @@map("device_tokens")
}
