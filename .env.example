# Database (Neon PostgreSQL — use the *pooler* endpoint in dev/serverless)
# Dashboard → Connection Details → "Pooled connection"
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/DB?sslmode=require"

# Clerk authentication
# Local dev: pk_test_ / sk_test_ (shows “Development mode” on sign-in)
# Production (Vercel): pk_live_ / sk_live_ from Clerk → Production instance
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/auth/continue"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/auth/continue"

# Public app URL (optional — Vercel sets VERCEL_URL automatically)
# APP_URL="https://personal-memorys.vercel.app"

# Resend (email reminders)
RESEND_API_KEY="re_..."
# Dev: onboarding@resend.dev | Production: verified domain (e.g. reminders@tudominio.com)
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Inngest (background jobs — optional until reminders cron is wired)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
